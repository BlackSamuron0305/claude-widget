<Window x:Class="ClaudeUsageHud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClaudeUsageHud"
        mc:Ignorable="d"
        Title="Claude Usage HUD"
        Width="300" Height="204"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        WindowStartupLocation="Manual">

    <Border x:Name="Card"
            CornerRadius="12"
            Background="#FA121214"
            BorderBrush="#14FFFFFF"
            BorderThickness="1"
            Padding="14,12,14,12"
            ClipToBounds="True"
            MouseLeftButtonDown="Card_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Claude Max"
                       FontSize="11" FontWeight="Medium"
                       Foreground="#8CFFFFFF"
                       Margin="0,0,0,10"/>

            <!-- Body: swaps between empty-state message and quota blocks -->
            <Grid Grid.Row="1">
                <TextBlock x:Name="EmptyStateText"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#66FFFFFF"
                           Visibility="Collapsed"/>

                <StackPanel x:Name="QuotaBlocks">
                    <!-- Session block -->
                    <Grid Margin="0,0,0,3">
                        <TextBlock Text="SESSION (5H)" FontSize="11" FontWeight="Medium" Foreground="#8CFFFFFF" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="SessionPctText" Text="--" FontSize="20" FontWeight="SemiBold" Foreground="#EBFFFFFF" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Height="6" Margin="0,5,0,4">
                        <Border x:Name="SessionTrack" CornerRadius="3" Background="#1AFFFFFF" Height="6"/>
                        <Border x:Name="SessionFill" CornerRadius="3" Background="#4ADE80" Height="6" Width="0" HorizontalAlignment="Left"/>
                    </Grid>
                    <TextBlock x:Name="SessionSubText" Text=" " FontSize="10" Foreground="#59FFFFFF" Margin="0,0,0,10"/>

                    <!-- Weekly block -->
                    <Grid Margin="0,0,0,3">
                        <TextBlock Text="WEEKLY (7D)" FontSize="11" FontWeight="Medium" Foreground="#8CFFFFFF" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="WeeklyPctText" Text="--" FontSize="20" FontWeight="SemiBold" Foreground="#EBFFFFFF" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Height="6" Margin="0,5,0,4">
                        <Border x:Name="WeeklyTrack" CornerRadius="3" Background="#1AFFFFFF" Height="6"/>
                        <Border x:Name="WeeklyFill" CornerRadius="3" Background="#4ADE80" Height="6" Width="0" HorizontalAlignment="Left"/>
                    </Grid>
                    <TextBlock x:Name="WeeklySubText" Text=" " FontSize="10" Foreground="#59FFFFFF"/>
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#40FFFFFF" Margin="0,0,5,0"/>
                <TextBlock x:Name="StatusText" Text="waiting for data..." FontSize="10" Foreground="#66FFFFFF"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
