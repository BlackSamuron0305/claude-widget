<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>ClaudeUsageHud</AssemblyName>
    <RootNamespace>ClaudeUsageHud</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- DPI awareness is declared in app.manifest (works for both the WPF window and
         WinForms tray icon). WFO0003 suggests the WinForms-only ApplicationHighDpiMode
         API instead, but that API has no effect on the WPF half of this app, so the
         manifest declaration is kept and the warning suppressed rather than acted on. -->
    <NoWarn>$(NoWarn);WFO0003</NoWarn>

    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

</Project>
