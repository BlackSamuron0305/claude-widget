{
  "name": "claude-usage-widget",
  "version": "2.0.0",
  "description": "A small always-on-top HUD showing Claude Max session/weekly usage, sourced from the Claude Code statusline.",
  "main": "main.js",
  "author": "BlackSamuron0305",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/fix-electron-install.js",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.claudewidget.usagehud",
    "productName": "Claude Usage HUD",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "portable"
    }
  }
}
